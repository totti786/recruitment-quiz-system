generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id                Int      @id @default(autoincrement())
  username          String   @unique
  password          String
  isDefaultPassword Boolean  @default(true)
  role              String   @default("ADMIN")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  departments       AdminDepartment[]
  auditLogs         AuditLog[]
}

model AdminDepartment {
  adminId      Int
  departmentId Int
  admin        Admin      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([adminId, departmentId])
}

model Department {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  positions   Position[]
  candidates  Candidate[]
  questions   Question[]
  quizzes     Quiz[]
  sessions    Session[]
  admins      AdminDepartment[]
}

model Position {
  id            Int         @id @default(autoincrement())
  name          String
  departmentId  Int
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  candidates    Candidate[]

  @@unique([name, departmentId])
  @@index([departmentId])
}

model Candidate {
  id              Int               @id @default(autoincrement())
  name            String
  phoneNumber     String
  email           String?
  departmentId    Int
  positionId      Int
  notes           String?
  department      Department        @relation(fields: [departmentId], references: [id])
  position        Position          @relation(fields: [positionId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        CandidateSession[]

  @@unique([name, phoneNumber])
  @@index([departmentId])
  @@index([positionId])
}

model Quiz {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  category    String
  questionCount Int          @default(10)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  departmentId Int
  department   Department    @relation(fields: [departmentId], references: [id])
  sessionQuizzes SessionQuiz[]

  @@index([departmentId])
}

model Session {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  timeLimit   Int            @default(60)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  departmentId Int
  department   Department    @relation(fields: [departmentId], references: [id])
  quizzes     SessionQuiz[]
  candidateSessions CandidateSession[]

  @@index([departmentId])
}

model SessionQuiz {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  quizId      Int
  order       Int
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([sessionId, quizId])
}

model CandidateSession {
  id              Int          @id @default(autoincrement())
  candidateId     Int
  sessionId       Int
  currentQuizIndex Int         @default(0)
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  status          String       @default("ACTIVE")
  timeRemaining   Int          // in seconds
  tabSwitchCount  Int          @default(0)
  isFullyGraded   Boolean      @default(false)  // Whether all answers have been graded
  gradedAt        DateTime?    // When the session was fully graded
  gradedBy        String?      // Who completed the grading
  candidate       Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  session         Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answers         Answer[]
  events          SessionEvent[]

  @@unique([candidateId, sessionId])
}

model Question {
  id           Int            @id @default(autoincrement())
  questionText String         @unique
  type         String         // MULTIPLE_CHOICE, SHORT_ANSWER, CODE
  category     String
  difficulty   String         // EASY, MEDIUM, HARD
  codeSnippet  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  departmentId Int
  department   Department     @relation(fields: [departmentId], references: [id])
  choices      Choice[]
  answers      Answer[]

  @@index([departmentId])
}

model Choice {
  id         Int      @id @default(autoincrement())
  questionId Int
  choiceText String
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    Answer[]
}

model Answer {
  id               Int              @id @default(autoincrement())
  candidateSessionId Int
  questionId       Int
  quizIndex        Int?             // tracks which quiz in the session this answer belongs to (optional for backward compatibility)
  selectedChoiceId Int?
  textAnswer       String?
  isCorrect        Boolean?
  score            Float?           // Manual score for written/code questions (0-100)
  maxScore         Int?             // Maximum possible score for this question
  isGraded         Boolean          @default(false)  // Whether this answer has been graded
  gradingNotes     String?          // Feedback/notes from grader
  gradedAt         DateTime?        // When the answer was graded
  gradedBy         String?          // Who graded the answer
  answeredAt       DateTime         @default(now())
  candidateSession CandidateSession @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)
  selectedChoice   Choice?          @relation(fields: [selectedChoiceId], references: [id], onDelete: SetNull)
   question         Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model SessionEvent {
  id                 Int      @id @default(autoincrement())
  candidateSessionId Int
  eventType          String   // TAB_SWITCH | REFRESH | FULLSCREEN_EXIT
  metadata           String?  // Optional JSON string with event context
  createdAt          DateTime @default(now())

  candidateSession   CandidateSession @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)

  @@index([candidateSessionId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int
  actor      Admin    @relation(fields: [actorId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   Int?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
}